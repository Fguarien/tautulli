version: "3.9"
services:
  tautulli:
    image: ghcr.io/linuxserver/tautulli:latest
    container_name: tautulli
    ports:
      - "8282:8181"
    environment:
      - PUID=1026
      - PGID=100
      - TZ=Europe/Brussels
    volumes:
      - /volume1/docker/tautulli/config:/config
      - /volume1/docker/tautulli/logs:/logs
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8181/status"]
      interval: 30s
      timeout: 5s
      retries: 5
    restart: always
    mem_limit: 12g
    mem_reservation: 2g
